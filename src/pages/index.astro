---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';

const featuredPosts = [
  {
    title: "SimplePractice vs TherapyNotes",
    excerpt: "A comprehensive comparison of the two most popular practice management platforms for solo therapists.",
    category: "Practice Management",
    href: "/blog/simplepractice-vs-therapynotes"
  },
  {
    title: "Best Practice Management Software",
    excerpt: "The top practice management tools for therapists in 2024, reviewed and ranked by real users.",
    category: "Practice Management",
    href: "/blog/best-practice-management-software"
  },
  {
    title: "TherapyNotes Review",
    excerpt: "An honest review of TherapyNotes: features, pricing, pros, cons, and who it's best for.",
    category: "Practice Management",
    href: "/blog/therapynotes-review"
  },
  {
    title: "How to Bill Insurance as a Therapist",
    excerpt: "A step-by-step guide to billing insurance as a therapist, including the best software tools.",
    category: "Billing",
    href: "/blog/how-to-bill-insurance"
  },
  {
    title: "Best HIPAA Telehealth Platforms",
    excerpt: "The most secure and reliable telehealth platforms for therapists that actually meet HIPAA requirements.",
    category: "Telehealth",
    href: "/blog/best-hipaa-telehealth-platforms"
  },
  {
    title: "Best Accounting Software for Therapists",
    excerpt: "Top accounting tools for self-employed therapists, from tax prep to invoicing.",
    category: "Finance",
    href: "/blog/best-accounting-software"
  }
];
---

<BaseLayout title="Therapist Tools">
  <section class="hero">
    <div class="container">
      <h1>Find the best software for your therapy practice</h1>
      <p class="subtitle">Honest reviews and comparisons to help therapists choose the right tools — without the marketing fluff.</p>
      <a href="/blog" class="btn">Start here</a>
    </div>
  </section>
  
  <section class="featured-posts">
    <div class="container">
      <h2>Featured Guides</h2>
      <div class="grid grid-3">
        {featuredPosts.map(post => (
          <PostCard 
            title={post.title}
            excerpt={post.excerpt}
            category={post.category}
            href={post.href}
          />
        ))}
      </div>
    </div>
  </section>
  
  <section class="trust-section">
    <div class="container">
      <h2>Why trust us</h2>
      <ul class="trust-list">
        <li>No sponsored content</li>
        <li>Verified by practicing therapists</li>
        <li>Updated regularly</li>
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    background: linear-gradient(135deg, var(--navy) 0%, #2d3a5a 100%);
    color: var(--white);
    padding: 5rem 0;
    text-align: center;
  }
  
  .hero h1 {
    color: var(--white);
    font-size: 2.5rem;
    max-width: 800px;
    margin: 0 auto 1rem;
  }
  
  .subtitle {
    font-size: 1.25rem;
    color: var(--gray-200);
    max-width: 600px;
    margin: 0 auto 2rem;
  }
  
  .featured-posts {
    padding: 4rem 0;
  }
  
  .featured-posts h2 {
    text-align: center;
    margin-bottom: 2rem;
  }
  
  .trust-section {
    background: var(--gray-50);
    padding: 4rem 0;
  }
  
  .trust-section h2 {
    text-align: center;
    margin-bottom: 1.5rem;
  }
  
  .trust-list {
    max-width: 500px;
    margin: 0 auto;
    list-style: none;
    text-align: center;
  }
  
  .trust-list li {
    padding: 0.75rem 0;
    font-size: 1.125rem;
    color: var(--gray-800);
  }
  
  .trust-list li::before {
    content: "✓ ";
    color: var(--teal);
    font-weight: bold;
    margin-right: 0.5rem;
  }
</style>
