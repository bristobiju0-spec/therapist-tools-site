---
import { getCollection, getEntry } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import AffiliateButton from '../../components/AffiliateButton.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const hasVerdict = post.body.includes('## Quick Verdict') || post.body.includes('##Verdict') || post.body.includes('**Quick Verdict');

function calculateReadingTime(text: string): number {
  const wordsPerMinute = 200;
  const words = text.split(/\s+/).length;
  return Math.ceil(words / wordsPerMinute);
}

const readingTime = calculateReadingTime(post.body);

let processedContent = post.body;

const affiliateMatches = processedContent.match(/\[AFFILIATE_LINK_([^\]]+)\]/g);
if (affiliateMatches) {
  const uniqueProducts = [...new Set(affiliateMatches.map(m => m.match(/\[AFFILIATE_LINK_([^\]]+)\]/)?.[1] || ''))];
  
  for (const product of uniqueProducts) {
    if (product) {
      const affiliateTag = `[AFFILIATE_LINK_${product}]`;
      const buttonHtml = `<div class="affiliate-wrapper"><a href="#" class="affiliate-btn">Try ${product} free &rarr;</a><span class="affiliate-disclaimer">Affiliate link</span></div>`;
      processedContent = processedContent.replace(new RegExp(affiliateTag.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'g'), buttonHtml);
    }
  }
}
---

<PostLayout 
  title={post.data.title} 
  description={post.data.description}
  pubDate={post.data.pubDate}
  category={post.data.category}
  readingTime={readingTime}
>
  {hasVerdict && (
    <div class="verdict-box">
      <h3>Quick Verdict</h3>
      <p>Based on our analysis, both platforms have their strengths. Choose based on your specific needs.</p>
    </div>
  )}
  
  <Fragment set:html={processedContent.replace(/\[AFFILIATE_LINK_[^\]]+\]/g, '')} />
</PostLayout>

<style>
  .verdict-box {
    background: var(--gray-50);
    border: 2px solid var(--teal);
    border-radius: 0.5rem;
    padding: 1.5rem;
    margin: 1.5rem 0;
  }
  
  .verdict-box h3 {
    color: var(--teal);
    margin-bottom: 0.5rem;
  }
  
  :global(.affiliate-wrapper) {
    margin: 1.5rem 0;
  }
  
  :global(.affiliate-btn) {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background: var(--teal);
    color: var(--white);
    border-radius: 0.375rem;
    font-weight: 600;
    text-decoration: none;
  }
  
  :global(.affiliate-btn:hover) {
    background: var(--teal-light);
  }
  
  :global(.affiliate-disclaimer) {
    display: block;
    font-size: 0.7rem;
    color: var(--gray-400);
    margin-top: 0.25rem;
  }
</style>
